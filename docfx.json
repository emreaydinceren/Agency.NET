{
  "metadata": [
    {
      "src": [
        {
          "src": "src",
          "files": [ "**/*.csproj" ],
          "exclude": [ "**/*.Test.csproj", "PackageSmokeTest/**" ]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0",
        "Configuration": "Release"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "**/*.yml", "index.md" ],
        "src": "api",
        "dest": "api"
      },
      {
        "files": [ "**/*.md", "**/toc.yml" ],
        "src": "docs",
        "dest": "docs",
        "exclude": [ "walkthrough/**" ]
      },
      {
        "files": [ "toc.yml", "index.md" ]
      }
    ],
    "resource": [
      {
        "files": [ "attachments/**", "walkthrough/**" ],
        "src": "docs",
        "dest": "docs"
      }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appTitle": "Agency",
      "_appName": "Agency",
      "_appFooter": "Agency — Apache-2.0 licensed.",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/emreaydinceren/Agency.NET",
        "branch": "main"
      }
    }
  }
}
