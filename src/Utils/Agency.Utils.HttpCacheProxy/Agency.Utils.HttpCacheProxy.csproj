<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <UserSecretsId>agency-utils-httpcacheproxy</UserSecretsId>
    <Description>Configurable HTTP caching reverse proxy for local developer testing. Listens on one or more ports, caches responses by request parameters, and forwards cache misses to target URLs. Emits OpenTelemetry metrics and structured logs to local files.</Description>
    <PackageTags>agency.net;proxy;cache;http;utils;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenTelemetry" />
    <PackageReference Include="Serilog" />
    <PackageReference Include="Serilog.Extensions.Logging" />
    <PackageReference Include="Serilog.Sinks.File" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
