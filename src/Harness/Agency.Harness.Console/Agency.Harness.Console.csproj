<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <UserSecretsId>agency-harness-console</UserSecretsId>
    <Description>Multi-turn interactive REPL chat harness built on Agency.Harness. Drop-in console host for testing agent prompts, tools, and stop conditions without writing a UI.</Description>
    <PackageTags>agency.net;ai;agent;repl;console;chat;dotnet</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Agency.Harness\Agency.Harness.csproj" />
    <ProjectReference Include="..\..\Llm\Agency.Llm.Common\Agency.Llm.Common.csproj" />
    <ProjectReference Include="..\..\Memory\Agency.Memory.Distiller\Agency.Memory.Distiller.csproj" />
    <ProjectReference Include="..\..\Memory\Agency.Memory.Sql.Postgres\Agency.Memory.Sql.Postgres.csproj" />
    <ProjectReference Include="..\..\Memory\Agency.Memory.Sql.Sqlite\Agency.Memory.Sql.Sqlite.csproj" />
    <ProjectReference Include="..\..\Memory\Agency.Memory.Consolidator\Agency.Memory.Consolidator.csproj" />
    <ProjectReference Include="..\..\Memory\Agency.Memory.Hygiene\Agency.Memory.Hygiene.csproj" />
    <ProjectReference Include="..\..\Embeddings\Agency.Embeddings.OpenAI\Agency.Embeddings.OpenAI.csproj" />
    <ProjectReference Include="..\..\VectorStore\Agency.VectorStore.Common\Agency.VectorStore.Common.csproj" />
    <ProjectReference Include="..\..\Ingestion\Agency.Ingestion\Agency.Ingestion.csproj" />
    <ProjectReference Include="..\..\Ingestion\Agency.Ingestion.FileSystem\Agency.Ingestion.FileSystem.csproj" />
    <ProjectReference Include="..\..\Ingestion\Agency.Ingestion.SemanticKernel\Agency.Ingestion.SemanticKernel.csproj" />
    <ProjectReference Include="..\..\VectorStore\Agency.VectorStore.Sql.Sqlite\Agency.VectorStore.Sql.Sqlite.csproj" />
    <ProjectReference Include="..\..\VectorStore\Agency.VectorStore.Sql.Postgres\Agency.VectorStore.Sql.Postgres.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" />
    <PackageReference Include="Microsoft.Extensions.Configuration.EnvironmentVariables" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Hosting" />
    <PackageReference Include="OpenTelemetry" />
    <PackageReference Include="Serilog" />
    <PackageReference Include="Serilog.Extensions.Logging" />
    <PackageReference Include="Serilog.Sinks.File" />
    <PackageReference Include="Spectre.Console" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
